# examples/subrepos/myrepo/build.hancho

import hancho

util_o = hancho.Task(
    desc    = "Compile {in_src}",
    command = "g++ -c {in_src} -o {out_obj}",
    in_src  = "util.cpp",
    out_obj = "{ext(in_src, '.o')}"
)

