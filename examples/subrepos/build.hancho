# examples/subrepos/build.hancho

myrepo = hancho.repo("myrepo/build.hancho")

main_o = hancho.task(
    command = "g++ -c {in_src} -o {out_obj}",
    in_src = "main.cpp",
    out_obj = "{ext(in_src, '.o')}"
)

main = hancho.task(
    command = "g++ {in_obj} -o {out_bin}",
    in_obj = [main_o, myrepo.util_o],
    out_bin = "main"
)
