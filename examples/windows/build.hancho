# hancho/examples/windows/build.hancho - Builds a trivial Win32 app.

import hancho

base_rules = hancho.load("{hancho_dir}/tools/tools_base.hancho")

main_o = hancho.Task(base_rules.compile_cpp, in_src="src/main.cpp")

main_exe = hancho.Task(base_rules.link_cpp_bin, in_objs=main_o, out_bin="app.exe")
