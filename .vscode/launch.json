{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [

    {
      "name"    : "CUSTOM",
      "type"    : "debugpy",
      "request" : "launch",
      "console" : "integratedTerminal",
      "cwd"     : "${workspaceFolder}/scratch",
      "program" : "${workspaceFolder}/hancho.py",
      "args"    : ["-v", "--rebuild"],
      //"args"    : ["-d", "-j1"],
      //"args"    : ["TestTasks.test_async_callback"],
    },

    {
      "name"    : "hancho.py",
      "type"    : "debugpy",
      "request" : "launch",
      "console" : "integratedTerminal",
      "program" : "${workspaceFolder}/hancho.py",
      //"args"    : ["-v", "--rebuild", "--debug"],
      //"args"    : ["--rebuild"],
      "cwd"     : "${workspaceFolder}",
    },

    {
      "name"    : "Tests",
      "type"    : "debugpy",
      "request" : "launch",
      "console" : "integratedTerminal",
      "module"  : "unittest",
      "args"    : ["tests.test_tasks"],
      "cwd"     : "${workspaceFolder}",
    },

    {
      "name": "Megabuild",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hancho.py",
      "cwd": "${workspaceFolder}/..",
      //"args": ["--force", "-j1"],
      "console": "integratedTerminal",
      "justMyCode": false,
      //"preLaunchTask": "Wipe build",
    },
  ]
}
