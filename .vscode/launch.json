  "version": "0.2.0",
  "configurations": [

    {
      "name"    : "Debug ${workspaceFolder]/hancho.py",
      "type"    : "debugpy",
      "request" : "launch",
      "program" : "${workspaceFolder}/hancho.py",
      "args"    : [],
      "cwd"     : "${workspaceFolder}",
      "console" : "integratedTerminal",
    },

    {
      "name": "Debug run_tests.py in repo root",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_tests.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "preLaunchTask": "Wipe build",
    },

    {
        "name": "Debug other stuff",
        "type": "debugpy",
        "request": "launch",
        "program": "test_hancho_as_import.py",
        "cwd": "${workspaceFolder}/tests",
        "console": "integratedTerminal",
        "justMyCode": true
    },

