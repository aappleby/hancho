  "version": "0.2.0",
  "configurations": [

    {
      "name"    : "Debug test module",
      "type"    : "debugpy",
      "request" : "launch",
      "module"  : "tests.test_tasks",
    },

    {
      "name"    : "Debug Hancho module",
      "type"    : "debugpy",
      "request" : "launch",
      "module"  : "hancho",
      "args"    : ["-C", "examples/dynamic_dependencies", "-d", "-v", "-j1"],
      //"cwd"     : "${workspaceFolder}/examples/dynamic_dependencies",
      //"program" : "${workspaceFolder}/hancho.py",
      //"args"    : ["-v", "--rebuild", "--debug"],
    },

    //{
    //  "name"    : "Tests",
    //  "type"    : "debugpy",
    //  "request" : "launch",
    //  "module"  : "unittest",
    //  "args"    : ["tests.test_tasks"],
    //},

    {
        // python -m unittest discover -s tests
        "name": "All tests in ${workspaceFolder}/tests",
        "type": "debugpy",
        "request": "launch",
        "module": "unittest",
        "args": ["discover"],
        "cwd": "${workspaceFolder}/tests",
        "env": { "PYTHONPATH": "${workspaceFolder}" },
    },

    {
      "name": "Megabuild",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hancho.py",
      "cwd": "${workspaceFolder}/..",
      //"args": ["--force", "-j1"],
      //"preLaunchTask": "Wipe build",
    },
  ]
}
