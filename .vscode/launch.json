{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [

    {
      "name"    : "Debug one test",
      "type"    : "debugpy",
      "request" : "launch",
      //"module"  : "tests.test_tasks",
      "module"  : "unittest",
      "args"    : ["tests.test_tasks.TestTasks.test_run_tasks_zero"],
      "preLaunchTask": "Wipe build",
    },

    {
      "name"    : "Debug all tests",
      "type"    : "debugpy",
      "request" : "launch",
      "module"  : "unittest",
      "preLaunchTask": "Wipe build",
    },

    {
      "name"    : "Debug hancho.py",
      "type"    : "debugpy",
      "request" : "launch",
      "module"  : "hancho",
      "args"    : ["-d", "-v", "-j1"],
      //"cwd"     : "${workspaceFolder}/examples/dynamic_dependencies",
      //"program" : "${workspaceFolder}/hancho.py",
      //"args"    : ["-v", "--rebuild", "--debug"],
      "preLaunchTask": "Wipe build",
    },

    {
      "name"    : "Debug example",
      "type"    : "debugpy",
      "request" : "launch",
      "module"  : "hancho",
      "args"    : ["-C", "examples/dynamic_dependencies", "-d", "-v", "-j1"],
      //"cwd"     : "${workspaceFolder}/examples/dynamic_dependencies",
      //"program" : "${workspaceFolder}/hancho.py",
      //"args"    : ["-v", "--rebuild", "--debug"],
      "preLaunchTask": "Wipe build",
    },

    {
      // python -m unittest discover -s tests
      "name": "All tests in ${workspaceFolder}/tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": ["discover"],
      "cwd": "${workspaceFolder}/tests",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "preLaunchTask": "Wipe build",
    },

    {
      "name": "Megabuild",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hancho.py",
      "cwd": "${workspaceFolder}/..",
      //"args": ["--force", "-j1"],
      "preLaunchTask": "Wipe build",
    },
  ]
}
