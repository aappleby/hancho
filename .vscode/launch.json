{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [

    {
      "name"    : "Debug hancho.py",
      "type"    : "debugpy",
      "request" : "launch",
      "console" : "integratedTerminal",
      "program" : "${workspaceFolder}/hancho.py",
      "args"    : [],
      "cwd"     : "${workspaceFolder}",
    },

    {
      "name"    : "Debug tests/run_tests.py",
      "type"    : "debugpy",
      "request" : "launch",
      "console" : "integratedTerminal",
      "program" : "${workspaceFolder}/tests/run_tests.py",
      "cwd"     : "${workspaceFolder}/tests",
      //"justMyCode": false,
      //"preLaunchTask": "Wipe build",
    },

    {
      "name"    : "Debug other stuff",
      "type"    : "debugpy",
      "request" : "launch",
      "console" : "integratedTerminal",
      "program" : "${workspaceFolder}/hancho.py",
      "cwd"     : "${workspaceFolder}/scratch",
    },

    {
      "name": "Debug Megabuild",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/hancho.py",
      "cwd": "${workspaceFolder}/..",
      //"args": ["--force", "-j1"],
      "console": "integratedTerminal",
      "justMyCode": false,
      //"preLaunchTask": "Wipe build",
    },
  ]
}
