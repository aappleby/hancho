import hancho
import sys
import glob
import os
import time

run_test = hancho.Tool(
    desc    = r"Run test suite '{test_mod}'",
    command = "{sys.executable} -m unittest {test_mod} -v",
    sys     = sys,
)

tests = glob.glob("test_*.py")
for file in tests:
    hancho.Task(run_test, test_mod = os.path.basename(file))
